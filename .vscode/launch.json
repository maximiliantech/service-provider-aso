    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Service Provider",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/service-provider-aso/",
            "env": {
                "POD_NAMESPACE": "openmcp-system",
                "PATH": "${env:PATH}"
            },
        },
        {
            "name": "Debug E2E Tests",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${workspaceFolder}/test/e2e/",
            "env": {
                "POD_NAMESPACE": "openmcp-system",
                "PATH": "/opt/homebrew/bin:/opt/homebrew/sbin:${env:PATH}"
            },
        },
    ]
}